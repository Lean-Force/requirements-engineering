# LiteLLM(OpenAI 互換)経由で LLM を呼ぶ。サーバー側でのみ使用。
#
# LiteLLM プロキシを立てて、その OpenAI 互換エンドポイントに接続する想定。
#   参考: https://docs.litellm.ai/docs/proxy/quick_start

# LiteLLM プロキシの URL(省略時 http://localhost:4000)
LITELLM_BASE_URL=http://localhost:4000

# LiteLLM プロキシの API キー(仮想キー)
LITELLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# 使用モデル(LiteLLM 形式。省略時 claude-opus-4-8)
# 例: claude-opus-4-8 / anthropic/claude-opus-4-8 / gpt-4o など
# LITELLM_MODEL=claude-opus-4-8

# ストーリーマップの保存先実装の切替。
#   未設定/file : ローカル JSON ファイル(FileStoryMapRepository)
#   kv          : Cloudflare Workers KV(KvStoryMapRepository、本番用)
# STORAGE_BACKEND=file

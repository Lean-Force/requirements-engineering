# LLM は Claude Agent SDK 経由で呼ぶ(サーバー側でのみ使用)。
# 接続先は Amazon Bedrock(本番)か Anthropic API 直結(ローカル開発)のどちらか。

# ---- Amazon Bedrock 経由(本番 / EKS) ----
# AWS 認証は標準クレデンシャルチェーンに従う(EKS では IRSA がそのまま使える)。
CLAUDE_CODE_USE_BEDROCK=1
AWS_REGION=us-east-1
# モデルはインファレンスプロファイル形式でピニングする
ANTHROPIC_MODEL=us.anthropic.claude-opus-4-8

# ---- Anthropic API 直結(ローカル開発の代替) ----
# CLAUDE_CODE_USE_BEDROCK を外し、こちらを設定してもよい
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# ANTHROPIC_MODEL=claude-opus-4-8

# エージェントループの上限ターン数(省略時 24)
# CHAT_MAX_TURNS=24

# ストーリーマップの保存先ファイル(省略時 data/storymap.json)。
# E2E で本番サンプルを汚さないよう別ファイルに隔離する用途に使う。
# STORYMAP_FILE=data/storymap.json

# コンテキスト(参照資料 = Agent Skill)のワークスペース(省略時 data/workspace)。
# E2E の隔離用。
# CONTEXT_WORKSPACE=data/workspace

# ---- ローカル開発(もう1つの代替) ----
# このマシンの Claude Code ログイン(~/.claude)をそのまま使う
# CLAUDE_LOCAL_AUTH=1

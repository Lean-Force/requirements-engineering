{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "usm-ai-chat",
  "compatibility_date": "2025-03-25",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // ストーリーマップの保存先(KvStoryMapRepository が参照するバインディング)。
  // 事前に `wrangler kv namespace create STORYMAP_KV` で作成し、出力された id をここに入れる。
  "kv_namespaces": [
    {
      "binding": "STORYMAP_KV",
      "id": "de59d87796364be98210f4daf4808023"
    }
  ],
  // 平文で良い設定値。秘匿値(LITELLM_API_KEY)は `wrangler secret put` で別途登録する。
  "vars": {
    "STORAGE_BACKEND": "kv",
    "LITELLM_BASE_URL": "https://api.deepseek.com",
    "LITELLM_MODEL": "deepseek-chat"
  }
}
